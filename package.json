    "@mantine/dates": "7.17.8",
    "@mantine/hooks": "7.17.8",
    "@radix-ui/react-tooltip": "1.2.10",
    "@react-router/node": "7.17.0",
    "@react-router/serve": "7.17.0",
    "@tailwindcss/vite": "4.3.1",
    "@vercel/react-router": "1.3.1",
    "dayjs": "1.11.21",
    "echarts": "6.1.0",
    "echarts-for-react": "3.0.6",
    "isbot": "5.1.43",
    "ohash": "2.0.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.17.0",
    "react-router-dom": "7.17.0",
    "recharts": "2.15.4",
    "ufo": "1.6.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@faker-js/faker": "10.5.0",
    "@iconify/json": "2.2.488",
    "@prettier/plugin-oxc": "0.1.4",
    "@react-router/dev": "7.17.0",
    "@react-router/fs-routes": "7.17.0",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
