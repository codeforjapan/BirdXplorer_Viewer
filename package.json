{
  "name": "birdxplorer_viewer",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postinstall": "pnpm run typegen",
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --experimental-cli --write .",
    "format:ci": "prettier --experimental-cli --check .",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "pnpm run typegen && tsc --noEmit",
    "typegen": "react-router typegen",
    "orval": "orval",
    "test": "TZ=UTC vitest --run",
    "test:node": "pnpm run test --project node",
    "test:browser": "pnpm run test --project browser",
    "check": "pnpm typecheck && pnpm build && pnpm lint && pnpm format:ci && pnpm test"
  },
  "dependencies": {
    "@conform-to/dom": "1.19.4",
