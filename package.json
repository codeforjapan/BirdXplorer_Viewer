    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-typegen": "2.3.1",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "msw": "2.14.6",
    "orval": "8.18.0",
    "playwright": "1.61.1",
    "postcss": "8.5.14",
